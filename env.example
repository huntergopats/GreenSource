// Simple SQLite store: maps Google users -> Stripe customers + tracks free-tier usage.
// Stripe remains the source of truth for subscription status; this just caches it.
import Database from "better-sqlite3";

const db = new Database(process.env.DB_PATH || "greensource.db");
db.pragma("journal_mode = WAL");

db.exec(`
CREATE TABLE IF NOT EXISTS users (
  id INTEGER PRIMARY KEY AUTOINCREMENT,
  google_id TEXT UNIQUE NOT NULL,
  email TEXT,
  name TEXT,
  picture TEXT,
  stripe_customer_id TEXT,
  is_pro INTEGER DEFAULT 0,
  plan TEXT,
  calc_uses INTEGER DEFAULT 0,
  created_at INTEGER,
  updated_at INTEGER
);
`);

const now = () => Date.now();

export function upsertUser({ googleId, email, name, picture }) {
  const existing = db.prepare("SELECT * FROM users WHERE google_id = ?").get(googleId);
  if (existing) {
    db.prepare("UPDATE users SET email=?, name=?, picture=?, updated_at=? WHERE google_id=?")
      .run(email, name, picture, now(), googleId);
    return db.prepare("SELECT * FROM users WHERE google_id = ?").get(googleId);
  }
  db.prepare(`INSERT INTO users (google_id,email,name,picture,created_at,updated_at)
              VALUES (?,?,?,?,?,?)`).run(googleId, email, name, picture, now(), now());
  return db.prepare("SELECT * FROM users WHERE google_id = ?").get(googleId);
}

export function getUserById(id) {
  return db.prepare("SELECT * FROM users WHERE id = ?").get(id);
}
export function getUserByGoogleId(gid) {
  return db.prepare("SELECT * FROM users WHERE google_id = ?").get(gid);
}
export function getUserByCustomer(cid) {
  return db.prepare("SELECT * FROM users WHERE stripe_customer_id = ?").get(cid);
}
export function setStripeCustomer(userId, cid) {
  db.prepare("UPDATE users SET stripe_customer_id=?, updated_at=? WHERE id=?").run(cid, now(), userId);
}
export function setProStatus(userId, isPro, plan) {
  db.prepare("UPDATE users SET is_pro=?, plan=?, updated_at=? WHERE id=?")
    .run(isPro ? 1 : 0, plan || null, now(), userId);
}
export function incCalcUse(userId) {
  db.prepare("UPDATE users SET calc_uses = calc_uses + 1, updated_at=? WHERE id=?").run(now(), userId);
  return getUserById(userId).calc_uses;
}

export default db;
